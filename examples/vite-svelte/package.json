    "svelte-check": "^2.1.0",
    "svelte-jester": "^2.1.5",
    "svelte-preprocess": "^4.7.2",
    "ts-jest": "^27.1.0",
    "tslib": "^2.2.0",
    "typescript": "^4.3.2",
    "uvu": "^0.5.2",
    "vite": "^2.6.4"
